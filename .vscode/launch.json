{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Deepwiki-Open",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "api.api:app",
                "--reload",
                "--port",
                "8001"
            ],
            "jinja": true,
            "justMyCode": true
        },
        {
        "name": "2-current file",
        "type": "debugpy",
        "request": "launch",
        "program": "${file}",
        "env": {
            "PYTHONPATH": "${workspaceFolder}"
        },
        "console": "integratedTerminal",
        "cwd": "${workspaceFolder}",
        "justMyCode": false
        }
    ]
}
